<?xml version="1.0" encoding="utf-8"?>
<robot name="dual_nova5_robot">
  <!-- 公共基座 -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://dobot_description/meshes/nova5/bodyV2.STL" />
      </geometry>
      <material name="base_material">
        <color rgba="0.3 0.3 0.3 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://dobot_description/meshes/nova5/bodyV2.STL" />
      </geometry>
    </collision>
  </link>
  <link name="table">
    <!-- 视觉属性（黄色，不透明度0%） -->
    <visual>
      <!-- 方块相对于base_link的位置（根据需求调整xyz，此处示例放在base_link上方0.05m处） -->
      <origin xyz="0 0 -0.025" rpy="0 0 0" />
      <geometry>
        <!-- 尺寸：1.5m×1.5m×0.1m -->
        <box size="1.2 1.2 0.05" />
      </geometry>
      <material name="yellow_transparent">
        <!-- rgba：r=1（红）, g=1（绿）, b=0（蓝）→ 黄色；a=0（透明度0%） -->
        <color rgba="1 1 0 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.025" rpy="0 0 0" />
      <geometry>
        <box size="1.2 1.2 0.05" />
      </geometry>
    </collision>
  </link>

  <!-- 将方块固定到base_link -->
  <joint name="base_to_table" type="fixed">
    <parent link="base_link" />
    <child link="table" />
    <!-- 关节原点与visual中的origin一致（确保方块位置正确） 0.805 -->
    <origin xyz="0 1.0 0.0805" rpy="0 0 0" />
  </joint>

  <link name="left_base_fixed_link"/>
  <link name="right_base_fixed_link"/>
  <joint name="base_to_left_arm" type="fixed">  
    <parent link="base_link" />
    <child link="left_dummy_link" />
    <origin xyz="-0.37615 0.288 1.39488" rpy="0 2.35619449019234 3.14159265358979" />
  </joint>
  <joint name="base_to_left_arm_fixed" type="fixed">
    <parent link="base_link" />
    <child link="left_base_fixed_link" />
    <origin xyz="-0.37615 0.288 1.39488" rpy="0 0 0" />
  </joint>

  <joint name="base_to_right_arm" type="fixed">
    <parent link="base_link" />
    <child link="right_dummy_link" />
    <origin xyz="0.37615 0.288 1.39488" rpy="0 -2.35619449019234 3.14159265358979" />
  </joint>
  <joint name="base_to_right_arm_fixed" type="fixed">
    <parent link="base_link" />
    <child link="right_base_fixed_link" />
    <origin xyz="0.37615 0.288 1.39488" rpy="0 0 0" />
  </joint>

  <!-- 左手相机法兰盘 -->
  <joint name="left_tool_to_left_camera" type="fixed">
    <parent link="left_Link6" />
    <child link="left_camera_link" />
    <origin xyz="0 0 0" rpy="0 0 -1.57080287682252" />
  </joint>
  
  <!-- 右手相机法兰盘 -->
  <joint name="right_tool_to_right_camera" type="fixed">
    <parent link="right_Link6" />
    <child link="right_camera_link" />
    <origin xyz="0 0 0" rpy="0 0 1.57080287682252" />
  </joint>

  <!-- 左手安装关节（18mm法兰盘） -->
  <joint name="left_tool_to_left_hand" type="fixed">
    <parent link="left_Link6" />
    <child link="L_base_link" />
    <origin xyz="0 0 0" rpy="0 0 1.57080287682252" />
    <!-- <origin xyz="0 0 0.018" rpy="0 0 1.57080287682252" /> -->
  </joint>
  
  <!-- 右手安装关节（18mm法兰盘） -->
  <joint name="right_tool_to_right_hand" type="fixed">
    <parent link="right_Link6" />
    <child link="R_base_link" />
    <origin xyz="0 0 0" rpy="0 0 -1.57080287682252" />
    <!-- <origin xyz="0 0 0.018" rpy="0 0 -1.57080287682252" /> -->
  </joint>

  <link name="left_dummy_link"/>
  <link name="right_dummy_link"/>

